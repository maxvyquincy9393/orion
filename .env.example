# =============================================================
# EDITH Configuration
# Run `pnpm onboard` to configure this automatically.
# Manual setup: copy this file to .env and fill in the values.
# =============================================================

# ── REQUIRED: Database ───────────────────────────────────────
# PostgreSQL (production — recommended):
DATABASE_URL=postgresql://edith:edith@localhost:5432/edith
# SQLite (dev only — change provider in prisma/schema.prisma to "sqlite"):
# DATABASE_URL=file:./edith.db
DEFAULT_USER_ID=owner

# ── REQUIRED: Choose at least ONE provider ───────────────────

# Groq (recommended — free, fast): https://console.groq.com
GROQ_API_KEY=

# Google Gemini (free): https://aistudio.google.com
GEMINI_API_KEY=

# Ollama (local, no API key): https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic / Claude (paid): https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (paid): https://platform.openai.com
OPENAI_API_KEY=

# OpenRouter (multi-provider): https://openrouter.ai
OPENROUTER_API_KEY=

# ── OPTIONAL: Channels (configure via `pnpm onboard`) ────────

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# WhatsApp
WHATSAPP_ENABLED=false
WHATSAPP_MODE=baileys
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_ALLOWED_WA_IDS=
WHATSAPP_CLOUD_API_VERSION=v20.0

# WebChat
WEBCHAT_PORT=8080

# ── OPTIONAL: Voice — Fish Audio (S1 / S1-mini / Fish-Speech 1.5) ───────────
# Get API key: https://fish.audio  |  Model hub: https://fish.audio/model/
# Set FISH_AUDIO_MODEL_ID to a reference_id from the model hub
# Leave as "s1" to use Fish Audio S1 base model directly
FISH_AUDIO_ENABLED=false
FISH_AUDIO_API_KEY=
FISH_AUDIO_MODEL_ID=s1
FISH_AUDIO_LATENCY=balanced
# Optional: per-emotion voice overrides (comma-separated key:reference_id)
# e.g. "warm:abc123,urgent:def456,excited:ghi789"
FISH_AUDIO_EMOTION_MODELS=

# ── OPTIONAL: Vision ──────────────────────────────────────────
# Cloud providers work on both phone and laptop (just HTTP calls, zero local weight).
# Local Ollama model is desktop-only offline fallback — never runs on phone.
#
# VISION_ENGINE: "auto" (cloud-first) | "ollama" (force local, desktop only)
VISION_ENABLED=false
VISION_ENGINE=auto
# Cloud model selection (phone + laptop)
VISION_GEMINI_MODEL=gemini-2.0-flash    # recommended — free tier
VISION_OPENAI_MODEL=gpt-4o-mini
VISION_CLAUDE_MODEL=claude-haiku-4-5-20251001
# Local fallback (desktop offline only) — pull with: ollama pull moondream
# moondream=1.1GB | llava:7b=4.5GB (better quality, needs good hardware)
VISION_OLLAMA_MODEL=moondream

# ── OPTIONAL: Features ────────────────────────────────────────
LOG_LEVEL=info
PERSONA_ENABLED=true
VOICE_ENABLED=false
PYTHON_PATH=python
MEMRL_ALPHA=0.1
MEMRL_GAMMA=0.9
MEMRL_SIMILARITY_THRESHOLD=0.3
PERMISSIONS_FILE=permissions/permissions.yaml

# ── OPTIONAL: Email (Phase 8) ─────────────────────────────────
# Gmail OAuth2: https://console.cloud.google.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=

# Outlook OAuth2: https://portal.azure.com
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REFRESH_TOKEN=

# ── OPTIONAL: Calendar (Phase 8) ─────────────────────────────
GCAL_CLIENT_ID=
GCAL_CLIENT_SECRET=
GCAL_REFRESH_TOKEN=
OUTLOOK_CALENDAR_CLIENT_ID=
OUTLOOK_CALENDAR_CLIENT_SECRET=
OUTLOOK_CALENDAR_REFRESH_TOKEN=

# ── OPTIONAL: SMS / Phone — Twilio (Phase 8) ─────────────────
# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=
PHONE_WEBHOOK_URL=

# Android ADB fallback (free, requires USB debugging)
ANDROID_ADB_HOST=127.0.0.1
ANDROID_ADB_PORT=5037

# ── OPTIONAL: Security ────────────────────────────────────────
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# ── OPTIONAL: Redis (sessions + caching) ────────────────────
# Required for multi-instance deployments. In-memory fallback if unset.
# REDIS_URL=redis://localhost:6379

# ── OPTIONAL: Observability ──────────────────────────────────
# Sentry DSN for error tracking (leave empty to disable)
# SENTRY_DSN=
# Daily LLM cost budget in USD (alerts when exceeded)
LLM_DAILY_BUDGET_USD=10
