ANTHROPIC_API_KEY=
# optional, berbayar
OPENAI_API_KEY=
# gratis via AI Studio: aistudio.google.com
GEMINI_API_KEY=
# gratis: console.groq.com
GROQ_API_KEY=
OPENROUTER_API_KEY=
# gratis, local
OLLAMA_BASE_URL=http://localhost:11434
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WHATSAPP_ENABLED=false
WHATSAPP_MODE=baileys
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_ALLOWED_WA_IDS=
WHATSAPP_CLOUD_API_VERSION=v20.0
WEBCHAT_PORT=8080
DATABASE_URL=file:./edith.db
DEFAULT_USER_ID=owner
LOG_LEVEL=info
PERSONA_ENABLED=true
MEMRL_ALPHA=0.1
MEMRL_GAMMA=0.9
MEMRL_SIMILARITY_THRESHOLD=0.3
PERMISSIONS_FILE=permissions/permissions.yaml
VOICE_ENABLED=false
VISION_ENABLED=false
PYTHON_PATH=python

# ===== PHASE 8: EXTENDED CHANNELS =====

# --- Email (Gmail + Outlook) ---
# Gmail OAuth2: Get credentials from https://console.cloud.google.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=

# Outlook OAuth2: Get credentials from https://portal.azure.com
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REFRESH_TOKEN=

# --- Calendar (Google Calendar + Outlook) ---
# Google Calendar OAuth2 (may reuse Gmail credentials or use separate)
GCAL_CLIENT_ID=
GCAL_CLIENT_SECRET=
GCAL_REFRESH_TOKEN=

# Outlook Calendar OAuth2 (may reuse Outlook credentials or use separate)
OUTLOOK_CALENDAR_CLIENT_ID=
OUTLOOK_CALENDAR_CLIENT_SECRET=
OUTLOOK_CALENDAR_REFRESH_TOKEN=

# --- SMS (Twilio + Android ADB fallback) ---
# Twilio: Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Phone (Twilio Voice) ---
# Twilio Voice: Additional config beyond SMS
TWILIO_TWIML_APP_SID=
PHONE_WEBHOOK_URL=

# --- Android ADB (self-hosted SMS fallback, gratis) ---
# Requires Android phone with USB debugging enabled, connected to host
ANDROID_ADB_HOST=127.0.0.1
ANDROID_ADB_PORT=5037

# --- Security ---
# Admin token for draft confirmation and sensitive operations
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=
