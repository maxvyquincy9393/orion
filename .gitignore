# ============================================
# EDITH — .gitignore
# ============================================

# Environment variables & Config — NEVER commit
.env
.env.local
.env.*.local
edith.json
edith.*.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.egg-info/
.pytest_cache/
.Python
env/
venv/
ENV/
.venv-voice/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Build
dist/
build/
output/
*.egg-info

# Temporary
*.tmp
*.temp
*.cache
.cache/

# Coverage and testing
coverage/
*.coverage
.nyc_output/
test-results/

# Database
*.db
*.sqlite
*.sqlite3

# Local pnpm artifact folders that may appear inside tracked desktop node_modules
apps/desktop/node_modules/.pnpm/@types+plist@3.0.5/
apps/desktop/node_modules/.pnpm/dmg-license@1.0.11/

# Node.js & pnpm
node_modules/
pnpm-lock.yaml
package-lock.json
yarn.lock

# Electron app build output
out/
release/
dist/
*.asar

# Local models and large binary files
models/
*.onnx
*.bin
*.pt
*.safetensors
*.whisper
*.tflite

# Python venv & local environments
.venv/
.venv-voice/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# Electron app data & crash reports
~/.edith/
crashes/
*.dmp

# Claude Code temp files
.claude/
.claude-temp/

# Test fixtures (local/sensitive)
EDITH-ts/src/os-agent/__tests__/fixtures/*.json

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Testing & Coverage
coverage/
.nyc_output/
test-results/
*.coverage
