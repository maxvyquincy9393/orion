# EDITH monorepo pnpm configuration
#
# IMPORTANT: Always run `pnpm install` from the REPO ROOT, never from inside
# apps/ or packages/ subdirectories. Subdirectory installs create a standalone
# pnpm-lock.yaml that conflicts with the workspace root lockfile.
#
# Use `pnpm --filter <pkg> add <dep>` from root to add deps to sub-packages.

# Enforce a single shared lockfile at the workspace root.
shared-workspace-lockfile=true

# Prevent automatic recursive installs into workspace child packages.
recursive-install=false
