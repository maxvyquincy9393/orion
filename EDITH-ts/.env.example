# ── Provider API Keys (at least 1 required) ─────────────────────────
# Free via AI Studio: https://aistudio.google.com
GEMINI_API_KEY=
# Free: https://console.groq.com
GROQ_API_KEY=
# Paid: https://platform.openai.com
OPENAI_API_KEY=
# Paid: https://console.anthropic.com
ANTHROPIC_API_KEY=
# Multi-provider: https://openrouter.ai
OPENROUTER_API_KEY=
# Local (free): https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434

# ── Channel Tokens (all optional) ───────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WHATSAPP_ENABLED=false
WHATSAPP_MODE=baileys
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_ALLOWED_WA_IDS=
WHATSAPP_CLOUD_API_VERSION=v20.0

# ── Server & Database ──────────────────────────────────────────────
WEBCHAT_PORT=8080
GATEWAY_PORT=18789
GATEWAY_HOST=127.0.0.1
AUTO_START_GATEWAY=false
DATABASE_URL=file:./edith.db

# ── Identity & Behavior ────────────────────────────────────────────
DEFAULT_USER_ID=owner
LOG_LEVEL=info
LOG_FORMAT=text
LOG_FILE_MAX_SIZE_MB=10
LOG_FILE_MAX_FILES=5
PERSONA_ENABLED=true
CRITIQUE_ENABLED=true
CRITIQUE_THRESHOLD=0.75

# ── Memory (MemRL) ─────────────────────────────────────────────────
MEMRL_ALPHA=0.1
MEMRL_GAMMA=0.9
MEMRL_SIMILARITY_THRESHOLD=0.3
MEMRL_EXPERIENCE_REPLAY_ENABLED=false
MEMRL_REPLAY_BUFFER_SIZE=256
MEMRL_REPLAY_BATCH_SIZE=16
MEMRL_TD_LAMBDA_ENABLED=false
MEMRL_TD_LAMBDA_TRACE_DECAY=0.9
HYBRID_SEARCH_ENABLED=true
HYBRID_HYDE_ENABLED=false
HYBRID_RERANK_ENABLED=false

# ── Session ─────────────────────────────────────────────────────────
SESSION_COMPACTION_ENABLED=true
SESSION_CONTEXT_WINDOW_TOKENS=32000

# ── Voice (EDITH) ────────────────────────────────────────────────────
VOICE_ENABLED=true
VOICE_TTS_BACKEND=edge
VOICE_EDGE_VOICE=en-US-GuyNeural
VOICE_EDGE_RATE=-8%
VOICE_EDGE_PITCH=-5Hz
VOICE_DSP_ENABLED=true
VOICE_DSP_PRESET=tars

# ── Vision ──────────────────────────────────────────────────────────
VISION_ENABLED=false
VISION_ENGINE=gemini

# ── Engine Stats ────────────────────────────────────────────────────
ENGINE_STATS_ENABLED=true
ORCHESTRATOR_COST_ROUTING_ENABLED=false
CAUSAL_BAYESIAN_UPDATE_ENABLED=false
HIMES_FORGETTING_CURVE_ENABLED=false
HIMES_CONSOLIDATION_ENABLED=false

# ── Observability ────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=EDITH-ts
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces
METRICS_ENABLED=true
METRICS_PREFIX=edith_

# ── Agent Limits ─────────────────────────────────────────────────────
AGENT_MAX_LLM_CALLS=40
LATS_EARLY_STOP_THRESHOLD=0.95

# ── Permissions ─────────────────────────────────────────────────────
PERMISSIONS_FILE=permissions/permissions.yaml
ALLOW_PROACTIVE_CHANNEL_SEND=false
DAEMON_TRIGGER_COOLDOWN_MINUTES=30
DAEMON_TRIGGER_DEDUP_ENABLED=true

# ── Admin (optional) ────────────────────────────────────────────────
# ADMIN_TOKEN=your-secret-admin-token
