{
  "name": "edith",
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.1",
  "type": "module",
  "bin": {
    "edith": "./bin/edith.js"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "all": "tsx src/main.ts --mode all",
    "edith": "tsx src/main.ts --mode edith",
    "gateway": "tsx src/main.ts --mode gateway",
    "gateway:watch": "tsx watch src/main.ts --mode gateway",
    "build": "tsup src/main.ts --format esm --dts --external playwright",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:ci": "vitest run",
    "lint": "biome lint .",
    "lint:ci": "biome lint .",
    "typecheck": "tsc --noEmit",
    "doctor": "tsx src/cli/doctor.ts",
    "voice:deps:check": "tsx src/cli/voice-deps-check.ts",
    "voice:deps:setup": "tsx src/cli/voice-deps-setup.ts",
    "voice:wake:prepare": "tsx src/cli/voice-wake-prepare.ts",
    "onboard": "tsx src/cli/onboard.ts",
    "quickstart": "tsx src/cli/onboard.ts --flow quickstart",
    "setup": "tsx src/cli/onboard.ts --flow quickstart",
    "wa:scan": "tsx src/cli/onboard.ts --flow quickstart --channel whatsapp --whatsapp-mode scan",
    "wa:cloud": "tsx src/cli/onboard.ts --flow quickstart --channel whatsapp --whatsapp-mode cloud",
    "dedupe:causal-graph": "tsx src/cli/causal-graph-dedupe.ts --apply",
    "dedupe:causal-graph:dry-run": "tsx src/cli/causal-graph-dedupe.ts --dry-run",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/google": "^3.0.30",
    "@ai-sdk/openai": "^3.0.30",
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@google/generative-ai": "^0.24.1",
    "@lancedb/lancedb": "^0.26.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@prisma/client": "^6.19.2",
    "@slack/bolt": "^4.6.0",
    "ai": "^6.0.97",
    "apache-arrow": "^18.1.0",
    "baileys": "7.0.0-rc.9",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "execa": "^9.6.1",
    "fastify": "^5.7.4",
    "grammy": "^1.40.0",
    "groq-sdk": "^0.37.0",
    "js-yaml": "^4.1.0",
    "msedge-tts": "^2.0.4",
    "node-cron": "^4.2.1",
    "openai": "^6.22.0",
    "p-queue": "^9.1.0",
    "prom-client": "^15.1.3",
    "qrcode-terminal": "^0.12.0",
    "undici": "^6.23.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "4.0.18",
    "minimatch": "^10.2.4",
    "prisma": "^6.19.2",
    "rollup": "^4.59.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "playwright": "^1.58.2"
  },
  "pnpm": {
    "overrides": {
      "undici": "^6.23.0"
    }
  }
}
