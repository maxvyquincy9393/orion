generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Message {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  channel   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Thread {
  id        String   @id @default(cuid())
  userId    String
  state     String
  context   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, state])
}

model TriggerLog {
  id          String   @id @default(cuid())
  userId      String
  triggerName String
  actedOn     Boolean  @default(false)
  firedAt     DateTime @default(now())

  @@index([userId, firedAt])
}

model VoiceProfile {
  id             String   @id @default(cuid())
  userId         String
  profileName    String
  cloneType      String
  modelPath      String?
  referenceAudio String?
  createdAt      DateTime @default(now())

  @@index([userId, profileName])
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  title     String
  source    String
  createdAt DateTime @default(now())

  chunks DocumentChunk[]

  @@index([userId, createdAt])
}

/**
 * Phase 13 — DocumentChunk with citation metadata.
 * One chunk = one retrievable segment from a document.
 */
model DocumentChunk {
  id            String   @id @default(cuid())
  documentId    String
  userId        String
  content       String
  contextPrefix String
  chunkIndex    Int
  page          Int?
  section       String?
  vectorId      String?
  createdAt     DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
}

/**
 * Phase 13 — Knowledge graph entity (HippoRAG-inspired).
 */
model KnowledgeEntity {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  chunkIds  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromEdges KnowledgeEdge[] @relation("fromEntity")
  toEdges   KnowledgeEdge[] @relation("toEntity")

  @@unique([userId, name])
  @@index([userId, type])
}

/**
 * Phase 13 — Knowledge graph edge (entity relationship).
 */
model KnowledgeEdge {
  id            String @id @default(cuid())
  userId        String
  fromId        String
  toId          String
  relation      String
  weight        Float  @default(0.5)
  sourceChunkId String

  from KnowledgeEntity @relation("fromEntity", fields: [fromId], references: [id], onDelete: Cascade)
  to   KnowledgeEntity @relation("toEntity", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, relation])
  @@index([userId])
}

model PairingCode {
  id        String   @id @default(cuid())
  code      String   @unique
  channel   String
  senderId  String
  expiresAt DateTime
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([code])
  @@index([senderId, channel])
}

model ApprovedUser {
  id         String    @id @default(cuid())
  userId     String
  channel    String
  approvedAt DateTime  @default(now())
  revokedAt  DateTime?

  @@unique([userId, channel])
}

model DeviceToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique  // SHA-256 hashed
  userId     String
  channel    String
  deviceName String   @default("unknown")
  createdAt  DateTime @default(now())
  lastUsed   DateTime @updatedAt
  revokedAt  DateTime?

  @@index([userId])
}

model PairingSession {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String
  channel   String
  expiresAt DateTime
  used      Boolean  @default(false)
}

model UserProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  facts      Json
  opinions   Json
  topics     Json
  updatedAt  DateTime @updatedAt
}

/**
 * Memory Node with IEU (Intent-Experience-Utility) triplet support
 * 
 * Stores memories with:
 * - Q-value for Bellman Q-learning updates
 * - Utility score for ranking
 * - Metadata for intent tracking and experience context
 */
model MemoryNode {
  id         String   @id @default(cuid())
  userId     String
  content    String
  level      Int
  validFrom  DateTime @default(now())
  validUntil DateTime?
  category   String
  embedding  Bytes?
  
  // IEU Triplet components
  utilityScore   Float  @default(0.5)  // U: Utility score for ranking
  qValue         Float  @default(0.5)  // Q-value for Bellman updates
  
  // Metadata stores intent, experience context, feedback history
  metadata       Json?
  
  // Statistics
  retrievalCount Int    @default(0)
  successCount   Int    @default(0)

  @@index([userId, level])
  @@index([userId, validUntil])
  @@index([userId, qValue])      // Index for Q-value based retrieval
  @@index([userId, utilityScore]) // Index for utility-based ranking
}

/**
 * FTS5 Virtual Table for full-text search (OC-10)
 * 
 * Enables fast keyword search using SQLite FTS5 extension.
 * This is used by HybridRetriever for lexical search alongside
 * vector search for semantic similarity.
 * 
 * Note: FTS tables are virtual and don't use standard Prisma migrations.
 * The table must be created manually via raw SQL:
 * CREATE VIRTUAL TABLE MemoryNodeFTS USING fts5(content, content_rowid=rowid);
 */
model MemoryNodeFTS {
  rowid   Int    @id
  content String

  @@ignore // Virtual table, managed via raw SQL
}

/**
 * Usage Event for LLM observability (OC-11)
 *
 * Tracks all LLM API calls with:
 * - Token counts (prompt, completion, total)
 * - Cost estimation
 * - Latency metrics
 * - Success/failure rates
 * - Request metadata
 *
 * Uses ring buffer in UsageTracker for high-throughput scenarios.
 */
model UsageEvent {
  id        String   @id @default(cuid())
  userId    String
  sessionId String?

  // Provider and model
  provider String
  model    String

  // Token counts
  promptTokens     Int
  completionTokens Int
  totalTokens      Int

  // Cost estimation (USD)
  estimatedCostUsd Float

  // Performance metrics
  latencyMs Int

  // Request metadata
  requestType String // chat, embedding, function_calling, tool_use
  success     Boolean
  errorType   String?

  // Timestamps
  timestamp DateTime
  createdAt DateTime @default(now())

  // Indexes for efficient queries
  @@index([userId, timestamp])
  @@index([provider, model])
  @@index([timestamp])
}

/**
 * Tenant configuration for multi-tenancy (OC-12)
 *
 * Stores tenant-level configuration and resource quotas.
 * Used by WorkspaceResolver for tenant isolation.
 */
model Tenant {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  userId    String   @unique
  
  // Tenant metadata
  displayName String?
  tier        String   @default("free") // free, pro, enterprise
  
  // Resource limits (JSON for flexibility)
  limits Json @default("{\"maxMessagesPerDay\": 100, \"maxStorageMb\": 50, \"maxSkills\": 3, \"apiRateLimit\": 60}")
  
  // Feature flags
  features Json @default("{\"enableVoice\": false, \"enableVision\": false, \"enableCustomSkills\": false, \"enableApi\": false}")
  
  // Custom configuration
  customConfig Json?
  
  // Workspace path (relative to saasDataDir)
  workspacePath String?
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastAccessedAt DateTime @default(now())
  
  // Indexes
  @@index([tier])
  @@index([createdAt])
}

model CausalNode {
  id        String   @id @default(cuid())
  userId    String
  event     String
  eventKey  String   // Stage-3 enforced dedupe key (lower/trim normalized event)
  category  String
  createdAt DateTime @default(now())

  causesEdges CausalEdge[] @relation("from")
  effectEdges CausalEdge[] @relation("to")
  hyperEdges  HyperEdgeMembership[]

  @@index([userId, category])
  @@unique([userId, eventKey])
}

model CausalEdge {
  id        String   @id @default(cuid())
  userId    String
  fromId    String
  toId      String
  strength  Float    @default(0.5)
  evidence  Int      @default(1)
  createdAt DateTime @default(now())

  from CausalNode @relation("from", fields: [fromId], references: [id])
  to   CausalNode @relation("to", fields: [toId], references: [id])

  @@unique([fromId, toId])
  @@index([userId])
}

model HyperEdge {
  id       String   @id @default(cuid())
  userId   String
  relation String
  context  String
  memberSetHash String // Stage-3 enforced dedupe key (hash of normalized relation + member set)
  weight   Float    @default(0.5)
  members  HyperEdgeMembership[]

  @@index([userId])
  @@unique([userId, relation, memberSetHash])
}

model HyperEdgeMembership {
  hyperEdgeId String
  nodeId      String

  hyperEdge HyperEdge  @relation(fields: [hyperEdgeId], references: [id])
  node      CausalNode @relation(fields: [nodeId], references: [id])

  @@id([hyperEdgeId, nodeId])
}

/**
 * Phase 10 — Per-user preference sliders and CIPHER-inferred behavioral prefs.
 *
 * Stores both explicit (user-configured) and implicit (CIPHER-inferred) preferences.
 * personalityEngine reads this to build the per-user system prompt fragment.
 *
 * Slider ranges:
 *   formality    1 (casual) ↔ 5 (formal)
 *   verbosity    1 (brief)  ↔ 5 (detailed)
 *   humor        0 (none)   ↔ 3 (frequent)
 *   proactivity  1 (quiet)  ↔ 5 (very proactive)
 */
model UserPreference {
  userId              String   @id
  // Behavioral sliders
  formality           Float    @default(3)
  verbosity           Float    @default(2)
  humor               Float    @default(1)
  proactivity         Float    @default(3)
  // Language and address
  language            String   @default("auto")
  titleWord           String   @default("Sir")
  // Tone preset
  tonePreset          String   @default("jarvis")
  // CIPHER-inferred behavioral preferences (JSON array of BehavioralPref) — null means []
  behavioralPrefs     Json?
  // Custom personality traits (string[]) — null means []
  customTraits        Json?
  // History of slider values for temporal evolution tracking — null means {}
  preferenceHistory   Json?
  // Inference metadata
  inferenceConfidence Float    @default(0)
  lastInferredAt      DateTime?
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([lastInferredAt])
}

/**
 * Per-user channel delivery preferences.
 *
 * channelOrder is a JSON-encoded string[] of channel names in the user's
 * preferred delivery order (e.g. ["whatsapp","telegram","discord"]).
 * Channels not listed fall through to the global priority order.
 */
model UserChannelPreference {
  userId       String   @id
  channelOrder Json     @default("[]")
  updatedAt    DateTime @updatedAt
}

/**
 * Phase 10C — Preference signals captured for feedback learning.
 *
 * Each row is one signal event (explicit, barge-in, edit, or implicit).
 * UserPreferenceEngine processes pending signals in the background
 * to update preference sliders.
 */
model PreferenceSignal {
  id         String   @id @default(cuid())
  userId     String
  // Signal type: 'explicit' | 'barge-in' | 'edit' | 'implicit'
  signalType String
  // Dimension affected: 'verbosity' | 'formality' | 'humor' | 'language' | 'general'
  dimension  String
  // Raw signal value: +1 (increase) / -1 (decrease) / 0 (confirm)
  value      Float
  // Confidence of this single signal (0–1)
  confidence Float    @default(0.5)
  // Optional context for CIPHER-style inference
  context    Json?
  // Whether this signal has been processed into a preference update
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, processed])
  @@index([userId, createdAt])
}

/**
 * Phase 10B — User activity records for HabitModel.
 *
 * Stores message timestamps for each user so HabitModel can infer
 * active/quiet hours patterns without keeping full message content.
 * Records are automatically decayed and pruned.
 */
model ActivityRecord {
  id        String   @id @default(cuid())
  userId    String
  hour      Int      // 0-23 hour of day when activity was recorded
  dayOfWeek Int      // 0=Sunday … 6=Saturday
  weight    Float    @default(1.0)  // Decays over time
  timestamp DateTime @default(now())

  @@index([userId, timestamp])
  @@index([userId, hour])
}

/**
 * Phase 16 — Expo push tokens for mobile notification delivery.
 *
 * One user can have multiple devices (phone + tablet + etc.).
 * Tokens are automatically deregistered when Expo returns DeviceNotRegistered.
 * Token lifecycle: app startup → register → push notification delivery → deregister on error.
 */
model PushToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique          // Expo push token: ExponentPushToken[...]
  platform   String                    // "ios" | "android"
  appVersion String   @default("")
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
}

/**
 * Phase 21 — Aggregated emotion session snapshot per user.
 *
 * Persisted when a session ends or the mood tracker flushes,
 * enabling cross-session emotion trend analysis.
 */
model EmotionSession {
  id           String   @id @default(cuid())
  userId       String
  dominant     String
  valence      Float
  arousal      Float
  sampleCount  Int
  sessionStart DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

/**
 * Phase 22 — Persisted record of an autonomous mission.
 *
 * Stores the full plan DAG and final report for auditing and resumption.
 * dagJson: serialized MissionPlan.steps array
 * budgetJson: serialized MissionBudget
 * reportJson: serialized MissionReport (null while running)
 */
model MissionRecord {
  id         String   @id @default(cuid())
  userId     String
  title      String
  goal       String
  status     String
  dagJson    Json
  budgetJson Json
  reportJson Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

/**
 * Phase 24 — Feedback signal from an interaction for self-improvement.
 */
model FeedbackRecord {
  id             String   @id @default(cuid())
  userId         String
  interactionId  String
  signal         String
  reason         String
  topic          String
  skillUsed      String?
  promptVersion  String
  createdAt      DateTime @default(now())

  @@index([userId])
}

/**
 * Phase 24 — Versioned system prompt zone for prompt optimization.
 */
model PromptVersionRecord {
  id             String   @id @default(cuid())
  zone           String
  oldContent     String
  newContent     String
  reason         String
  evidenceJson   Json
  rollbackTarget String?
  createdAt      DateTime @default(now())

  @@index([zone])
}

/**
 * Phase 25 — Pre-action state snapshot for rollback support.
 */
model ActionSnapshotRecord {
  id             String   @id @default(cuid())
  actionId       String
  type           String
  target         String
  preState       String
  postState      String?
  childSnapshots Json     @default("[]")
  reversible     Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([actionId])
}

/**
 * Phase 26 — Registered Legion instance for multi-instance orchestration.
 */
model LegionInstance {
  id         String   @id @default(cuid())
  instanceId String   @unique
  role       String
  url        String
  online     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/**
 * Phase 27 — Paired user device for cross-device mesh routing.
 */
model PairedDevice {
  id           String   @id @default(cuid())
  deviceId     String   @unique
  userId       String
  name         String
  os           String
  type         String
  gatewayId    String
  capabilities Json     @default("[]")
  lastSeen     DateTime @default(now())
  paired       DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
}

/**
 * Phase 27 — Gateway peer for cross-network sync.
 */
model GatewayPeer {
  id        String   @id @default(cuid())
  gatewayId String   @unique
  userId    String
  url       String
  online    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/**
 * Auto-reply template for automated responses (keyword/regex/schedule-based).
 * Created via API or skill command; matched by auto-reply matcher in the pipeline.
 */
model AutoReplyTemplate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  trigger     String
  triggerType String   @default("keyword")
  response    String
  channels    Json     @default("[]")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
}

/**
 * Phase 28 — Immutable audit trail for all significant actions.
 */
model AuditRecord {
  id        String   @id @default(cuid())
  userId    String
  action    String
  channel   String?
  input     String?
  output    String?
  risk      String   @default("low")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([risk])
  @@index([createdAt])
}
